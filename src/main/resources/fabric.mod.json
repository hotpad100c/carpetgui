    "main": [
      "ml.mypals.carpetgui.CarpetGUI"
    ],
    "client": [
      "ml.mypals.carpetgui.CarpetGUIClient"
    ]
  },
  "mixins": [
    "carpetgui.mixins.json"
  ],
  "accessWidener": "carpetgui.accesswidener",
  "depends": {
    "fabricloader": ">=0.15",
    "minecraft": "${minecraft}",
	"fabric-api": "*"
  }
